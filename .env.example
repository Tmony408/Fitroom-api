# Copy to .env and fill in
DATABASE_URL="postgresql://fitroom:fitroom@localhost:5432/fitroom?schema=public"
JWT_SECRET="change-me-in-production-please"
ACCESS_TOKEN_TTL="15m"          # short-lived access token (Batch 1.5)
PORT=3000
CORS_ORIGIN="http://localhost:3001"

# Email (Batch 1.5) — verify + password reset
EMAIL_DRIVER="console"          # console (logs links) | brevo
EMAIL_FROM="no-reply@fitroom.io"
EMAIL_FROM_NAME="FitRoom"
# BREVO_API_KEY="xkeysib-..."   # required when EMAIL_DRIVER=brevo

# Scan / measurement capture (Batch 3)
STORAGE_DRIVER="local"          # local | s3 (s3 = future)
STORAGE_DIR="./storage"         # where local scan images are written
SCAN_RETENTION_DAYS=7           # scan images purged after N days

# Payments (Batch 4)
APP_URL="http://localhost:3001"   # frontend URL for payment callbacks
PAYMENT_PROVIDER="mock"           # mock | paystack
COMMISSION_BPS=800                # marketplace commission, basis points (800 = 8%)
# PAYSTACK_SECRET_KEY="sk_test_..."  # required when PAYMENT_PROVIDER=paystack
